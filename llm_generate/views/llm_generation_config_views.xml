<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!-- Generation Config Form View -->
    <record id="llm_generation_config_view_form" model="ir.ui.view">
        <field name="name">llm.generation.config.view.form</field>
        <field name="model">llm.generation.config</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button
                            name="toggle_active"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-archive"
                        >
                            <field
                                name="active"
                                widget="boolean_toggle"
                                options="{'terminology': 'archive'}"
                            />
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Configuration Name" />
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="model_id" />
                            <field name="description" />
                        </group>
                    </group>
                    <notebook>
                        <page string="Input Schema" name="input_schema">
                            <field name="input_schema" widget="ace" />
                        </page>
                        <page string="Output Schema" name="output_schema">
                            <field name="output_schema_raw" widget="ace" />
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" />
                    <field name="message_ids" />
                </div>
            </form>
        </field>
    </record>

    <!-- Generation Config Tree View -->
    <record id="llm_generation_config_view_tree" model="ir.ui.view">
        <field name="name">llm.generation.config.view.tree</field>
        <field name="model">llm.generation.config</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name" />
                <field name="model_id" />
                <field name="active" invisible="1" />
            </tree>
        </field>
    </record>

    <!-- Generation Config Search View -->
    <record id="llm_generation_config_view_search" model="ir.ui.view">
        <field name="name">llm.generation.config.view.search</field>
        <field name="model">llm.generation.config</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" />
                <field name="model_id" />
                <separator />
                <filter
                    string="Archived"
                    name="inactive"
                    domain="[('active', '=', False)]"
                />
                <group expand="0" string="Group By">
                    <filter
                        string="Model"
                        name="group_by_model"
                        context="{'group_by': 'model_id'}"
                    />
                </group>
            </search>
        </field>
    </record>

    <!-- Generation Config Action -->
    <record id="llm_generation_config_action" model="ir.actions.act_window">
        <field name="name">Generation Configurations</field>
        <field name="res_model">llm.generation.config</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new generation configuration
            </p>
            <p>
                Generation configurations define the input and output schemas for non-chat generation tasks.
            </p>
        </field>
    </record>
</odoo>
