<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!-- Simplified Record Selector Wizard Form -->
    <record id="llm_prompt_record_selector_view_form" model="ir.ui.view">
        <field name="name">llm.prompt.record.selector.form</field>
        <field name="model">llm.prompt.record.selector</field>
        <field name="arch" type="xml">
            <form string="Select Related Record">
                <header>
                    <button
                            name="action_confirm_selection"
                            string="Select Record"
                            type="object"
                            class="oe_highlight"
                            attrs="{'invisible': ['|', ('model_id', '=', False), ('record_selection', '=', False)]}"
                    />
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1>Select Related Record</h1>
                        <p>Choose a record to use in your prompt testing</p>
                    </div>

                    <group>
                        <group>
                            <field
                                    name="model_id"
                                    options="{'no_create': True, 'no_create_edit': True}"
                                    placeholder="Select a model type..."
                            />
                        </group>
                        <group>
                            <field
                                    name="record_selection"
                                    attrs="{'invisible': [('model_id', '=', False)]}"
                                    placeholder="Select a record..."
                                    options="{'no_create': True}"
                            />
                        </group>
                    </group>

                    <!-- Show selected record info -->
                    <div
                            class="alert alert-success"
                            role="alert"
                            attrs="{'invisible': [('selected_record_name', '=', '')]}"
                    >
                        <strong>Selected Record:</strong>
                        <field name="selected_record_name" readonly="1" class="oe_inline"/>
                        <br/>
                        <strong>Model:</strong>
                        <field name="model_name" readonly="1" class="oe_inline"/>
                        <br/>
                        <strong>Record ID:</strong>
                        <field name="selected_record_id" readonly="1" class="oe_inline"/>
                    </div>

                    <!-- Instructions -->
                    <div class="alert alert-info" role="alert">
                        <h5>Instructions:</h5>
                        <ol>
                            <li><strong>Select Model Type:</strong> Choose the type of record (e.g., Contact, Product, Sales Order)</li>
                            <li><strong>Select Record:</strong> Choose a specific record from that model</li>
                            <li><strong>Confirm:</strong> Click "Select Record" to use this record in your prompt test</li>
                        </ol>

                        <h6>Common Model Types:</h6>
                        <ul class="small">
                            <li><strong>Contact (res.partner)</strong> - Customers, vendors, contacts</li>
                            <li><strong>Product (product.product)</strong> - Products and services</li>
                            <li><strong>Sales Order (sale.order)</strong> - Sales orders and quotations</li>
                            <li><strong>Invoice (account.move)</strong> - Customer invoices and vendor bills</li>
                            <li><strong>Project (project.project)</strong> - Projects and tasks</li>
                            <li><strong>Employee (hr.employee)</strong> - Company employees</li>
                        </ul>
                    </div>

                    <!-- Hidden fields -->
                    <field name="test_wizard_id" invisible="1"/>
                    <field name="model_name" invisible="1"/>
                </sheet>

                <footer>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
