<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Extend LLM Provider Form View for Letta -->
        <record id="view_llm_provider_form_letta" model="ir.ui.view">
            <field name="name">llm.provider.form.letta</field>
            <field name="model">llm.provider</field>
            <field name="inherit_id" ref="llm.llm_provider_view_form"/>
            <field name="arch" type="xml">
                <field name="api_base" position="after">
                    <field name="odoo_api_key"
                           password="True"
                           invisible="service != 'letta'"
                           placeholder="Enter your Odoo API key here"/>
                    <div class="alert alert-info" role="status" invisible="service != 'letta'">
                        <strong>Odoo API Key Required for Letta Agents</strong>
                        <p>This API key is required to create Letta agents that can access Odoo through MCP (Model Context Protocol).</p>
                        <p><strong>How to create an API key:</strong></p>
                        <ol>
                            <li>Click on your profile avatar (top right corner)</li>
                            <li>Go to <strong>Preferences</strong></li>
                            <li>Navigate to <strong>Account Security</strong> tab</li>
                            <li>Click <strong>"New API Key"</strong> button</li>
                            <li>Copy the generated key and paste it above</li>
                        </ol>
                        <p><small><em>Note: The API key will be validated when you save this provider configuration.</em></small></p>
                    </div>
                </field>
            </field>
        </record>
    </data>
</odoo>